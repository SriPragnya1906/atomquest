# Local dev database configuration (SQLite)
DATABASE_URL="file:./dev.db"

# JWT configuration
JWT_SECRET="your_secret_session_token_key"

# Environment
NODE_ENV="development"
PORT=3000

# NextAuth SSO Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# Microsoft OAuth SSO App Registration credentials
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_TENANT_ID="common"

# Microsoft Graph API Credentials (for Real Email sending instead of simulation)
MICROSOFT_GRAPH_CLIENT_ID=""
MICROSOFT_GRAPH_CLIENT_SECRET=""
MICROSOFT_GRAPH_TENANT_ID=""
